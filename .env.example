# NFP Analytics — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# In Vercel: add these via Project → Settings → Environment Variables.

# ─────────────────────────────────────────────────────────
# DASHBOARD_PASSWORD — required
# Shared password that protects the dashboard login screen.
# Anyone with this password can view the live dashboard.
# ─────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=your_shared_password_here

# ─────────────────────────────────────────────
# YOUTUBE
# How to get: Google Cloud Console (console.cloud.google.com)
#   → APIs & Services → Library → enable "YouTube Data API v3"
#   → APIs & Services → Credentials → Create Credentials → API Key
# Channel ID: go to your YouTube channel, click your profile → YouTube Studio
#   → Settings → Channel → Advanced settings — copy "Channel ID"
# ─────────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSy...
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# FACEBOOK
# How to get: developers.facebook.com → My Apps → Create App → Business
#   → Add "Pages" product → Generate a Page Access Token for your page
#   To get a long-lived token (60 days): exchange via Graph API Explorer
#     GET /oauth/access_token?grant_type=fb_exchange_token&...
# Page ID: go to your Facebook Page → About → scroll to bottom for Page ID
# ─────────────────────────────────────────────
FACEBOOK_PAGE_ID=123456789012345
FACEBOOK_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# INSTAGRAM (Business Account via Facebook Graph API)
# How to get: Your Instagram account must be a Business or Creator account
#   linked to a Facebook Page.
#   In Graph API Explorer: GET /{facebook-page-id}?fields=instagram_business_account
#   to find your Instagram Business Account ID.
#   Uses the same FACEBOOK_PAGE_ACCESS_TOKEN above (needs instagram_basic,
#   instagram_manage_insights permissions).
# ─────────────────────────────────────────────
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841xxxxxxxxxx

# ─────────────────────────────────────────────
# LINKEDIN (OAuth 2.0 — requires interactive browser login)
# How to get: linkedin.com/developers → Create App → select your Company Page
#   → Products tab → request "Share on LinkedIn" and "Marketing Developer Platform"
#   → Auth tab → copy Client ID and Client Secret
#   → Add OAuth 2.0 redirect URL: http://localhost:3000/api/linkedin/callback
# Organization ID: your LinkedIn Company Page URL ends in /company/XXXXXXX
#   — that number is your Organization ID.
# ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_ORGANIZATION_ID=12345678
#   Add redirect URL in LinkedIn App → Auth: https://your-project.vercel.app/api/linkedin?type=callback

# ─────────────────────────────────────────────
# FLODESK
# How to get: app.flodesk.com → Account Settings (bottom left) → Integrations
#   → API → copy your API Key
# ─────────────────────────────────────────────
FLODESK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
